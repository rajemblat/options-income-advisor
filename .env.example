# Schwab Trader API (developer.schwab.com) — dejar vacío mientras el acceso está pendiente de aprobación.
# Con broker.mode: mock en config/settings.yaml no hacen falta estas dos variables.
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_REDIRECT_URI=https://127.0.0.1:8182/callback

# Anthropic (narrador de alertas, claude-haiku-4-5-20251001)
ANTHROPIC_API_KEY=

# Finnhub (finnhub.io) — fecha de próximos earnings y noticias recientes por símbolo, y
# calendario económico (CPI/empleo/PBI/FOMC) si el plan lo incluye. Sin key, estos datos
# quedan en blanco (no rompe el pipeline).
FINNHUB_API_KEY=

# FRED (fred.stlouisfed.org/docs/api/api_key.html) — tasa de fondos federales vigente, CPI
# interanual, desempleo y crecimiento del PBI. Gratis, requiere registro. Sin key, estos
# datos quedan en blanco.
FRED_API_KEY=

# Kalshi (probabilidad de decisión de la Fed) no necesita API key — los datos de mercado son
# públicos (ver market_context/kalshi_client.py).
